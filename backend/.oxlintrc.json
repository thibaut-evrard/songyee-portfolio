{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "import", "jsx-a11y"],
  "env": {
    "browser": true,
    "es2024": true
  },
  "rules": {
    "no-unused-vars": "error",
    "eqeqeq": "error",
    "typescript/no-explicit-any": "warn",
    "import/no-unresolved": "error",
    "jsx-a11y/alt-text": "error"
  },
  "settings": {
    "jsx": "preserve"
  }
}
